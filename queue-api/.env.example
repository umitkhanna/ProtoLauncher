# Sync from main app: from repo root run  npm run worker:env
# (copies DATABASE_* and REDIS_* from .env.local or .env into queue-api/.env)

# Copy this file to queue-api/.env and fill in values.
# DATABASE_* can be omitted here if they are already set in the repo root .env.local
# (the worker loads .env.local first, then this file).

# Redis (same host/port as Next.js producer)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_URL=redis://127.0.0.1:6379

# MySQL (same database as main app — worker writes projects.requirements_document)
DATABASE_HOST=127.0.0.1
DATABASE_USER=your_mysql_user
DATABASE_PASSWORD=your_mysql_password
DATABASE_NAME=your_database_name
# DATABASE_SSL=true

# Claude (Anthropic) — primary for this worker
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: OpenAI instead / fallback selection
# AI_PROVIDER=anthropic
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
