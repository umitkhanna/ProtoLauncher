# Set to your production URL for canonical links, sitemap, and OG.
NEXT_PUBLIC_SITE_URL=https://protolauncher.vercel.app

# MySQL (required for registration, login, and password reset)
DATABASE_HOST=127.0.0.1
DATABASE_USER=your_mysql_user
DATABASE_PASSWORD=your_mysql_password
DATABASE_NAME=your_database_name
# DATABASE_SSL=true
# DATABASE_POOL_LIMIT=10

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# AI for requirements generation (server only — never expose to client)
# Next.js reads .env.local only; backlog generation also reads AI_* from queue-api/.env if keys are missing here.
# Prefer one provider; if AI_PROVIDER is unset, Anthropic is used when ANTHROPIC_API_KEY is set, else OpenAI when OPENAI_API_KEY is set.
# AI_PROVIDER=openai
# AI_PROVIDER=anthropic
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Redis (BullMQ) — Next.js enqueues jobs; run worker:requirements or your own consumer
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_URL=redis://127.0.0.1:6379

# BullMQ worker (queue-api): copy DATABASE_*, REDIS_*, and optional AI_* into queue-api/.env
#   npm run worker:env

# Dev only: include debugResetUrl in forgot-password JSON (never on public production)
# AUTH_DEBUG_RESET_LINK=true
